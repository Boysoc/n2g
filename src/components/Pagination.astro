---
import LinkButton from "./LinkButton.astro";

export interface Props {
  currentPage: number;
  totalPages: number;
  prevUrl: string;
  nextUrl: string;
}

const { currentPage, totalPages, prevUrl, nextUrl } = Astro.props;

const prev = currentPage > 1 ? "" : "disabled";
const next = currentPage < totalPages ? "" : "disabled";

// 生成页码数组
const pageNumbers = [];
for (let i = 1; i <= totalPages; i++) {
  pageNumbers.push(i);
}
---

{
  totalPages > 1 && (
    <nav class="pagination-wrapper content" aria-label="分页导航">
      <LinkButton
        disabled={prev === "disabled"}
        href={prevUrl}
        className={`page-btn prev-btn ${prev}`}
        ariaLabel="上一页"
      >
        &lt;
      </LinkButton>

      {pageNumbers.map((pageNum) => (
        <LinkButton
          href={pageNum === 1 ? "/posts/" : `/posts/${pageNum}/`}
          className={`page-btn ${currentPage === pageNum ? "active" : ""}`}
          ariaLabel={`第 ${pageNum} 页`}
        >
          {pageNum}
        </LinkButton>
      ))}

      <LinkButton
        disabled={next === "disabled"}
        href={nextUrl}
        className={`page-btn next-btn ${next}`}
        ariaLabel="下一页"
      >
        &gt;
      </LinkButton>
    </nav>
  )
}

<style is:global>
  .pagination-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 1.5rem 0;
  }

  .page-btn {
    display: inline-flex;
    min-width: 38px;
    height: 38px;
    align-items: center;
    justify-content: center;
    user-select: none;
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    background: var(--color-bg-surface);
    font-size: 0.9rem;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .page-btn:hover:not(.disabled) {
    color: var(--color-primary-500);
    border-color: var(--color-border-primary);
    background: var(--color-bg-surface-elevated);
  }

  .page-btn.active {
    border-color: var(--color-action-bg);
    background: var(--color-action-bg);
    color: var(--color-action-text);
    font-weight: 600;
  }

  .page-btn.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  .prev-btn {
    margin-right: 0.6rem;
  }

  .next-btn {
    margin-left: 0.6rem;
  }
</style>
