---
import type { CollectionEntry } from "astro:content";
import { groupPostsByDate, getArchiveStats, getMonthName } from "@utils/archiveHelper";

export interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;

const postGroups = groupPostsByDate(posts);
const stats = getArchiveStats(posts);
---

<section class="archive-container">
  <!-- 统计头部 -->
  <header class="archive-header">
    <h1 class="archive-title">时光之旅</h1>
    <p class="stats-text">
      <span class="highlight">{stats.totalPosts}</span> 篇文章
      <span class="separator">·</span>
      <span class="highlight">{stats.totalYears}</span> 年旅程
    </p>
  </header>

  <!-- 时间轴 -->
  <div class="visual-timeline">
    {postGroups.map((group) => (
      <div class="year-section" id={`year-${group.year}`} data-year={group.year}>
        <div class="year-label">
          <span class="year-text">{group.year}</span>
          <div class="year-line"></div>
        </div>

        <div class="months-grid">
          {group.months.map((monthGroup) => (
            <div class="month-block">
              <div class="month-dot" data-count={monthGroup.count}>
              </div>
              <div class="month-tooltip">
                <div class="tooltip-month">{getMonthName(monthGroup.month)}</div>
                <div class="tooltip-count">{monthGroup.count} 篇文章</div>
              </div>
            </div>
          ))}
        </div>

        <!-- 文章列表 -->
        <div class="posts-list">
          {group.months.map(monthGroup => (
            monthGroup.posts.map(post => (
              <a href={`/posts/${post.slug}/`} class="post-item">
                <span class="post-date">
                  {new Date(post.data.pubDatetime).toLocaleDateString("zh-CN", {
                    month: '2-digit',
                    day: '2-digit'
                  })}
                </span>
                <span class="post-title-text">{post.data.title}</span>
              </a>
            ))
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- 年份导航 -->
  <nav class="years-navigation" aria-label="年份导航">
    <div class="nav-title">时光穿梭</div>
    <div class="nav-years">
      {postGroups.map((group) => (
        <a href={`#year-${group.year}`} class="nav-year" data-year={group.year}>
          {group.year}
        </a>
      ))}
    </div>
  </nav>
</section>

<style>
  .archive-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1em 2em;
    position: relative;
  }

  /* 头部 */
  .archive-header {
    text-align: center;
    margin-bottom: 3.5em;
  }

  .archive-title {
    font-size: var(--font-size-page-title);
    font-weight: 700;
    color: var(--color-primary-500);
    margin-bottom: 0.4em;
    font-family: "Noto Serif SC", serif;
    letter-spacing: 0.05em;
  }

  .stats-text {
    font-size: 1.1em;
    color: var(--color-text-tertiary);
    margin: 0;
  }

  .highlight {
    font-weight: 700;
    color: var(--color-primary-500);
  }

  .separator {
    margin: 0 0.5em;
    opacity: 0.6;
  }

  /* 时间轴 */
  .visual-timeline {
    margin-top: 2em;
    margin-bottom: 3em;
  }

  .year-section {
    margin-bottom: 3.5em;
  }

  .year-section:last-child {
    margin-bottom: 1em;
  }

  .year-label {
    display: flex;
    align-items: center;
    margin-bottom: 1.2em;
  }

  .year-text {
    font-size: 1.6em;
    font-weight: 700;
    color: var(--color-primary-500);
    margin-right: 1.2em;
    min-width: 4.5em;
    text-align: right;
  }

  .year-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-primary-400), transparent);
    opacity: 0.5;
  }

  /* 月份热力点 */
  .months-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0.4em;
    margin-bottom: 1.5em;
    padding-left: 5.7em;
  }

  .month-block {
    position: relative;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .month-dot {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .month-dot::before {
    content: '';
    position: absolute;
    width: 8px;
    height: 8px;
    background-color: var(--color-border-default);
    border-radius: 50%;
    transition: all 0.25s ease;
  }

  .month-dot[data-count="1"]::before {
    background-color: var(--color-primary-300);
    width: 11px;
    height: 11px;
  }

  .month-dot[data-count="2"]::before {
    background-color: var(--color-primary-400);
    width: 15px;
    height: 15px;
  }

  .month-dot[data-count="3"]::before {
    background-color: var(--color-primary-500);
    width: 19px;
    height: 19px;
  }

  .month-dot[data-count]:not([data-count="0"]):hover::before {
    transform: scale(1.4);
    background-color: var(--color-primary-500);
    box-shadow: 0 0 8px rgba(39, 174, 96, 0.4);
  }

  /* Tooltip */
  .month-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-bg-surface-elevated);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-default);
    padding: 0.4em 0.7em;
    border-radius: 6px;
    font-size: 0.75em;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    z-index: 10;
    box-shadow: var(--shadow-md);
  }

  .month-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: var(--color-border-default);
  }

  .month-block:hover .month-tooltip {
    opacity: 1;
  }

  .tooltip-month {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .tooltip-count {
    color: var(--color-text-tertiary);
  }

  /* 文章列表 */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0.3em;
    padding-left: 5.7em;
  }

  .post-item {
    display: flex;
    align-items: baseline;
    gap: 1em;
    padding: 0.5em 0.8em;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    border: 1px solid transparent;
  }

  .post-item:hover {
    background-color: var(--color-bg-surface);
    border-color: var(--color-border-subtle);
    box-shadow: var(--shadow-sm);
  }

  .post-date {
    font-size: 0.8em;
    color: var(--color-text-tertiary);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    min-width: 3.5em;
  }

  .post-title-text {
    font-size: 0.95em;
    line-height: 1.5;
    color: var(--color-text-secondary);
    transition: color 0.2s ease;
  }

  .post-item:hover .post-title-text {
    color: var(--color-text-link);
  }

  /* 年份导航 */
  .years-navigation {
    position: fixed;
    bottom: 2em;
    right: 2em;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    backdrop-filter: blur(10px);
    padding: 0.8em 1em;
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
    z-index: 100;
    max-width: 180px;
  }

  .nav-title {
    font-size: 0.8em;
    font-weight: 600;
    color: var(--color-primary-500);
    margin-bottom: 0.5em;
    text-align: center;
  }

  .nav-years {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4em;
  }

  .nav-year {
    padding: 0.25em 0.5em;
    font-size: 0.8em;
    color: var(--color-text-tertiary);
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .nav-year:hover,
  .nav-year.active {
    background-color: var(--color-primary-50);
    color: var(--color-primary-500);
  }

  :global([data-theme="dark"]) .nav-year:hover,
  :global([data-theme="dark"]) .nav-year.active {
    background-color: rgb(39 174 96 / 10%);
    color: var(--color-primary-300);
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .archive-container {
      padding: 1em 0.5em;
    }

    .year-text {
      font-size: 1.3em;
      min-width: 3.5em;
      margin-right: 0.8em;
    }

    .months-grid {
      padding-left: 4.3em;
      gap: 0.2em;
    }

    .posts-list {
      padding-left: 4.3em;
    }

    .post-item {
      padding: 0.4em 0.5em;
    }

    .years-navigation {
      bottom: 1em;
      right: 1em;
      padding: 0.6em 0.8em;
      max-width: 150px;
    }
  }

  @media (max-width: 480px) {
    .months-grid {
      padding-left: 0;
    }

    .posts-list {
      padding-left: 0;
    }

    .year-text {
      min-width: auto;
      margin-right: 0.6em;
    }

    .years-navigation {
      position: static;
      margin-top: 2em;
      max-width: 100%;
    }

    .post-item {
      flex-direction: column;
      gap: 0.2em;
    }
  }
</style>

<script>
  function initArchiveFeatures() {
    // 年份导航点击
    const navYears = document.querySelectorAll('.nav-year');
    navYears.forEach(navYear => {
      navYear.addEventListener('click', (e) => {
        e.preventDefault();
        const year = navYear.getAttribute('data-year');
        if (year) {
          const section = document.querySelector(`.year-section[data-year="${year}"]`);
          if (section) {
            section.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });

    // 滚动高亮当前年份
    const yearSections = document.querySelectorAll('.year-section');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const year = entry.target.getAttribute('data-year');
          navYears.forEach(nav => {
            nav.classList.toggle('active', nav.getAttribute('data-year') === year);
          });
        }
      });
    }, { threshold: 0.2 });

    yearSections.forEach(section => observer.observe(section));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initArchiveFeatures);
  } else {
    initArchiveFeatures();
  }

  document.addEventListener('astro:after-swap', initArchiveFeatures);
</script>
