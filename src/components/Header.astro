---
import { SITE } from "@config";

interface Props {
  activeNav?: string;
  showHeader?: boolean;
}

const { activeNav = "" } = Astro.props;

const navItems = [
  { title: "首页", href: "/", key: "home" },
  { title: "归档", href: "/archive/", key: "archive" },
  { title: "友链", href: "/links/", key: "links" },
  { title: "关于", href: "/about/", key: "about" },
];
---

<header data-site-header>
  <div class="top-nav-wrap content">
    <a href="/" class="logo" aria-label={`${SITE.title} 首页`}>
      <span class="logo-text">Xio's</span>
      <span class="logo-slogan">一切从简，记录生活。</span>
    </a>

    <nav id="nav-menu" aria-label="主导航">
      <ul id="menu-items">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class={activeNav === item.key ? "active" : ""}
                aria-current={activeNav === item.key ? "page" : undefined}
              >
                {item.title}
              </a>
            </li>
          ))
        }
      </ul>

      <a class="theme-btn" href="/search/" aria-label="搜索" title="搜索">
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </a>

      <button
        id="theme-btn"
        class="theme-btn"
        type="button"
        aria-label="切换明暗模式"
        aria-pressed="false"
        title="切换明暗模式"
      >
        <svg
          class="sun"
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <path
            d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
          ></path>
        </svg>
        <svg
          class="moon"
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <button
        id="hamburger-menu"
        class="hamburger-menu"
        type="button"
        aria-label="打开菜单"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M3 6h18M3 12h18M3 18h18"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  function initHeader() {
    const header = document.querySelector<HTMLElement>("[data-site-header]");
    const hamburger =
      header?.querySelector<HTMLButtonElement>("#hamburger-menu");
    const menu = header?.querySelector<HTMLElement>("#menu-items");
    if (!header || !hamburger || !menu) return;

    const previousController = (window as any).__n2gHeaderController as
      | AbortController
      | undefined;
    previousController?.abort();
    const controller = new AbortController();
    (window as any).__n2gHeaderController = controller;
    const options = { signal: controller.signal };

    const setOpen = (open: boolean) => {
      menu.classList.toggle("nav-open", open);
      hamburger.setAttribute("aria-expanded", String(open));
      hamburger.setAttribute("aria-label", open ? "关闭菜单" : "打开菜单");
    };

    hamburger.addEventListener(
      "click",
      () => setOpen(hamburger.getAttribute("aria-expanded") !== "true"),
      options,
    );
    menu
      .querySelectorAll("a")
      .forEach((link) =>
        link.addEventListener("click", () => setOpen(false), options),
      );
    document.addEventListener(
      "click",
      (event) => {
        if (!header.contains(event.target as Node)) setOpen(false);
      },
      options,
    );
    document.addEventListener(
      "keydown",
      (event) => {
        if (event.key === "Escape") setOpen(false);
      },
      options,
    );
  }

  initHeader();
  document.addEventListener("astro:page-load", initHeader);
</script>
