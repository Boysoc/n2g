---
import type { CollectionEntry } from "astro:content";
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Tag from "@components/Tag.astro";
import Datetime from "@components/Datetime";
import Comment from "@components/Comment.astro";
import { slugifyStr } from "@utils/slugify";

export interface Props {
  post: CollectionEntry<"blog">;
  prev?: CollectionEntry<"blog"> | null;
  next?: CollectionEntry<"blog"> | null;
}

const { post, next, prev } = Astro.props;
const { Content } = await post.render();
const {
  title,
  author,
  description,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
} = post.data;

function buildOgImageUrl(post: CollectionEntry<"blog">): string {
  const ogImage = post.data.ogImage;
  if (typeof ogImage === "string") {
    return ogImage.startsWith("http")
      ? ogImage
      : new URL(ogImage, Astro.url.origin).href;
  } else if (ogImage?.src) {
    return new URL(ogImage.src, Astro.url.origin).href;
  } else {
    return new URL(`/posts/${slugifyStr(title)}.png`, Astro.url.origin).href;
  }
}

const ogImageUrl = buildOgImageUrl(post);
const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage: ogImageUrl,
  scrollSmooth: true,
};
---

<Layout {...layoutProps}>
  <Header />
  <main id="main-content" class="content">
    <Datetime
      pubDatetime={pubDatetime}
      modDatetime={modDatetime}
      className="post-date"
    />
    <h1 transition:name={slugifyStr(post.slug)} class="post-title">{title}</h1>
    <article id="article" role="article" class="post-content">
      <Content />
    </article>

    {
      prev || next ? (
        <div class="related-post">
          <div class="prev-post">
            {prev && (
              <>
                <span class="date-box">← 上一篇</span>
                <h2 class="post-title" style="font-size: 1.2em;">
                  <a href={`/posts/${prev.slug}/`}>{prev.data.title}</a>
                </h2>
              </>
            )}
          </div>
          <div class="next-post">
            {next && (
              <>
                <span class="date-box">下一篇 →</span>
                <h2 class="post-title" style="font-size: 1.2em;">
                  <a href={`/posts/${next.slug}/`}>{next.data.title}</a>
                </h2>
              </>
            )}
          </div>
        </div>
      ) : null
    }

    <ul class="tag-list">
      {tags.map((tag) => <Tag tag={tag} />)}
    </ul>

    <div class="comment">
      <Comment />
    </div>
  </main>
  <Footer />
</Layout>

<script>
  function initPostDetails() {
    // 代码复制按钮
    const codeBlocks = document.querySelectorAll("pre");
    codeBlocks.forEach((code) => {
      if (
        !code.parentElement?.classList.contains("code-wrapper") &&
        code.children.length > 0
      ) {
        const codeWrapper = document.createElement("div");
        codeWrapper.classList.add("code-wrapper");
        codeWrapper.style.position = "relative";
        code.parentElement?.insertBefore(codeWrapper, code);
        codeWrapper.appendChild(code);

        const button = document.createElement("button");
        button.className = "copy-code";
        button.textContent = "复制";
        codeWrapper.appendChild(button);
      }
    });

    document.querySelectorAll<HTMLElement>(".copy-code").forEach((button) => {
      if (button.dataset.copyReady === "true") return;
      button.dataset.copyReady = "true";
      button.addEventListener("click", () => {
        const parent = button.parentElement;
        const codeblock = parent?.querySelector("pre > code");
        if (codeblock) {
          navigator.clipboard
            .writeText(codeblock.textContent || "")
            .then(() => {
              button.textContent = "已复制";
              setTimeout(() => {
                button.textContent = "复制";
              }, 2000);
            })
            .catch(() => {
              button.textContent = "失败";
              setTimeout(() => {
                button.textContent = "复制";
              }, 2000);
            });
        }
      });
    });

    // 阅读进度条（防止重复创建）
    if (!document.querySelector(".progress-container")) {
      const progressContainer = document.createElement("div");
      progressContainer.className = "progress-container";
      const bar = document.createElement("div");
      bar.className = "progress-bar";
      progressContainer.appendChild(bar);
      document.body.appendChild(progressContainer);

      window.addEventListener("scroll", () => {
        const winScroll =
          document.body.scrollTop || document.documentElement.scrollTop;
        const height =
          document.documentElement.scrollHeight -
          document.documentElement.clientHeight;
        const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
        bar.style.width = scrolled + "%";
      });
    }

    // 标题锚点链接
    document
      .querySelectorAll("#article h2, #article h3, #article h4")
      .forEach((heading) => {
        if (!heading.id || heading.querySelector(".heading-link")) return;
        const link = document.createElement("a");
        link.className = "heading-link";
        link.href = `#${heading.id}`;
        link.textContent = "#";
        link.setAttribute("aria-label", "段落链接");
        heading.appendChild(link);
      });
  }

  initPostDetails();
  document.addEventListener("astro:page-load", initPostDetails);
</script>
